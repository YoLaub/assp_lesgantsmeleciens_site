```mermaid
classDiagram
  direction TB

  %% ── Pattern Clean Architecture (gallery · actualites · disciplines) ──

  class ImageRepository {
    <<interface>>
    +getAll() Image[]
    +getByCategory(slug) Image[]
    +save(data) Image
    +saveMany(data) Image[]
    +delete(id) void
    +bulkDelete(ids) void
    +reorder(items) void
  }

  class ImageRepositoryImpl {
    -datasource ImagePostgresDatasource
    +getAll() Image[]
    +save(data) Image
    +bulkDelete(ids) void
    +reorder(items) void
  }

  class ImagePostgresDatasource {
    -prisma PrismaClient
    +findAll() Image[]
    +upsert(data) Image
    +deleteMany(ids) void
  }

  class ActualiteRepository {
    <<interface>>
    +getAll() Actualite[]
    +getActive() Actualite[]
    +getFeatured() Actualite
    +getById(id) Actualite
    +save(data) Actualite
    +reorder(ids) void
  }

  class ActualiteRepositoryImpl {
    -datasource ActualitePostgresDatasource
  }

  class DisciplineRepository {
    <<interface>>
    +getAll() Discipline[]
    +getActive() Discipline[]
    +getById(id) Discipline
    +save(data) Discipline
    +reorder(ids) void
  }

  class DisciplineRepositoryImpl {
    -datasource DisciplinePostgresDatasource
  }

  ImageRepositoryImpl ..|> ImageRepository : implements
  ImageRepositoryImpl --> ImagePostgresDatasource : uses
  ActualiteRepositoryImpl ..|> ActualiteRepository : implements
  DisciplineRepositoryImpl ..|> DisciplineRepository : implements

  %% ── Use Cases (exemple gallery) ──

  class SaveGalleryImageUseCase {
    -repo ImageRepository
    +execute(data) Image
  }

  class BulkDeleteGalleryImagesUseCase {
    -repo ImageRepository
    +execute(ids) void
  }

  class ReorderGalleryImagesUseCase {
    -repo ImageRepository
    +execute(items) void
  }

  SaveGalleryImageUseCase --> ImageRepository : uses
  BulkDeleteGalleryImagesUseCase --> ImageRepository : uses
  ReorderGalleryImagesUseCase --> ImageRepository : uses

  %% ── Pattern DDD v2 : thin SA → use-case → IRepository (adherents · essayants) ──

  class AdherentsServerActions {
    <<thin Server Actions wrappers>>
    +createAdherentAction(input) void
    +getMonDossierAction(token) Dossier
    +updateAdresseAction(token, data) void
    +uploadDocumentAdherentAction(token, file, type) void
    +createCheckoutAction(token) Session
    +validerEngagementAction(token) void
    +exportAdherentsCsvAction() Response
  }

  class EssayantsServerActions {
    <<thin Server Actions wrappers>>
    +createEssayantAction(input) void
    +pointerPresenceAction(id, coachToken, nom) void
    +getMonEssaiAction(token) Essai
    +genererCoachTokenAction() CoachToken
    +getEssayantsForCoachAction(coachToken) Essayant[]
  }

  class AdhesionRepositories {
    <<IMembreRepository + IInscriptionRepository>>
    +implémentés dans adhesion/data/
    +injectés dans les use-cases
  }

  AdherentsServerActions --> AdhesionRepositories : via use-cases
  EssayantsServerActions --> AdhesionRepositories : via use-cases
```
